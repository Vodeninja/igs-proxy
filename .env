# ---------------------------------------------------------------------------
# Reverse Proxy — Environment Configuration
# ---------------------------------------------------------------------------

# URL целевого API (без trailing slash)
# По умолчанию: https://gm-donate.net/api
API_ENDPOINT=https://gm-donate.net/api

# Таймаут запроса к upstream в секундах
# По умолчанию: 30.0
PROXY_TIMEOUT=30.0

# ---------------------------------------------------------------------------
# IP Whitelist
# ---------------------------------------------------------------------------
# Список разрешённых IP-адресов и/или CIDR-диапазонов через запятую.
#
# Варианты:
#
#   Пустое значение — whitelist отключён, пропускаются все IP:
#   ALLOWED_IPS=
#
#   Один IP:
#   ALLOWED_IPS=1.2.3.4
#
#   Несколько IP:
#   ALLOWED_IPS=1.2.3.4,5.6.7.8
#
#   CIDR-диапазон:
#   ALLOWED_IPS=10.0.0.0/8
#
#   Смешанный вариант (IP + диапазоны):
#   ALLOWED_IPS=1.2.3.4,10.0.0.0/8,192.168.1.0/24
#
#   IPv6 тоже поддерживается:
#   ALLOWED_IPS=::1,2001:db8::/32
#
# По умолчанию: пусто (все IP разрешены)
ALLOWED_IPS=
